<main class="page">
  <% contact_email_valid = @contact_email.present? && @contact_email.match?(URI::MailTo::EMAIL_REGEXP) %>
  <section class="hero">
    <div class="hero-copy soft-panel">
      <h1>
        Headroom cuts Claude Code costs 
        by ~<span class="headline-highlight">50%</span>
      </h1>
      <p class="lead">
        Headroom is a menu bar app that quietly optimizes all the inputs that Claude Code gets. <br/>
        It trims prompt bloat, strips boilerplate and compresses documents without throwing anything away.
      </p>

      <div class="actions">
        <% if @mac_download_url.present? %>
          <%= link_to "Download for macOS", @mac_download_url, class: "button button-primary" %>
        <% else %>
          <span class="button button-primary button-disabled">Download for macOS — coming soon</span>
        <% end %>
      </div>

      <div class="hero-features" aria-label="Headroom features">
        <article class="feature-card">
          <h3>Privacy first</h3>
          <p>Your prompts never touch our servers — everything runs locally on your machine.</p>
        </article>
        <article class="feature-card">
          <h3>Self-contained</h3>
          <p>Keeps your runtime clean, never interfering with packages your projects depend on.</p>
        </article>
        <article class="feature-card">
          <h3>Optimize your workflow</h3>
          <p>Run tools that improve your setup, so you become a little better at what you do every day.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="screenshots soft-panel" aria-labelledby="screenshots-title">
    <div class="section-heading">
      <p class="eyebrow">Headroom in action</p>
      <p>
        Headroom substantially reduces the cost of your Claude Code sessions by compressing the data it reads. Headroom also optimize your sessions by studying your historical Claude logs and writing learnings to memory.
      </p>
    </div>

    <div class="screenshot-grid">
      <article class="screenshot-frame screenshot-frame-primary">
        <%= image_tag "/screenshots/screenshot-1.png", alt: "Headroom savings dashboard", class: "screenshot-image screenshot-image-primary" %>
      </article>

      <div class="screenshot-stack">
        <article class="screenshot-frame">
          <%= image_tag "/screenshots/screenshot-2.png", alt: "Headroom optimization view", class: "screenshot-image screenshot-image-small" %>
        </article>
        <article class="screenshot-frame">
          <%= image_tag "/screenshots/screenshot-3.png", alt: "Headroom onboarding screen", class: "screenshot-image screenshot-image-small" %>
        </article>
      </div>
    </div>
  </section>

  <section class="pricing soft-panel" id="pricing" aria-labelledby="pricing-title">
    <div class="section-heading">
      <p class="eyebrow">Pricing</p>
      <p>
        Try it free. Upgrade in the app for cross-context continuity, or talk to us
        about Headroom for teams.
      </p>
    </div>

    <div class="pricing-grid">
      <article class="pricing-card">
        <div class="pricing-card__header">
          <div>
            <h3>Free</h3>
            <p>Local savings &amp; optimizations</p>
          </div>
          <div class="pricing-card__price">
            <strong>$0</strong>
            <span>/ month<br>free forever</span>
          </div>
        </div>

        <div class="pricing-card__features">
          <p>Includes:</p>
          <ul>
            <li>Run locally on 1 device</li>
            <li>Savings dashboard and stats</li>
            <li>Optimize Claude Code practices</li>
          </ul>
        </div>
      </article>

      <article class="pricing-card pricing-card-featured">
        <div class="pricing-card__header">
          <div>
            <h3>Pro</h3>
            <p>Continuity across contexts</p>
          </div>
          <div class="pricing-card__price">
            <strong>$4</strong>
            <span>USD / month<br>billed annually</span>
          </div>
        </div>

        <div class="pricing-card__features">
          <p>Everything in Free, plus:</p>
          <ul>
            <li>Track sessions across devices</li>
            <li>Sync learned patterns</li>
            <li>Priority support</li>
          </ul>
        </div>
      </article>

      <article class="pricing-card">
        <div class="pricing-card__header">
          <div>
            <h3>Team &amp; Enterprise</h3>
            <p>Shared controls, governance, and private deployment options</p>
          </div>
          <div class="pricing-card__price pricing-card__price-note">
            <strong>custom • contact us</strong>
          </div>
        </div>

        <%= form_with url: contact_request_path, scope: :contact_request, class: "contact-request__form", data: { contact_form: true } do |form| %>
          <%= form.email_field :email, value: @contact_email, required: true, placeholder: "you@company.com", class: "contact-request__input", data: { contact_email_input: true } %>
          <%= form.submit "Submit", class: "pricing-card__button pricing-card__button-secondary contact-request__submit#{contact_email_valid ? " is-ready" : ""}", disabled: !contact_email_valid, data: { contact_submit: true } %>
        <% end %>
      </article>
    </div>
  </section>
  <footer class="site-footer">
    <p>Made by <a href="https://www.garm.com" target="_blank" rel="noopener">Garm Tech</a>, powered by <a href="https://github.com/chopratejas/headroom" target="_blank" rel="noopener">Headroom</a> by <a href="https://x.com/chopra_tejas" target="_blank" rel="noopener">Tejas Chopra</a></p>
  </footer>
</main>

<script>
  (function () {
    function syncContactFormState() {
      document.querySelectorAll("[data-contact-form]").forEach(function (form) {
        var emailInput = form.querySelector("[data-contact-email-input]");
        var submitButton = form.querySelector("[data-contact-submit]");

        if (!emailInput || !submitButton) {
          return;
        }

        var ready = emailInput.validity.valid && emailInput.value.trim().length > 0;
        submitButton.disabled = !ready;
        submitButton.classList.toggle("is-ready", ready);
      });
    }

    document.addEventListener("input", function (event) {
      if (event.target && event.target.matches("[data-contact-email-input]")) {
        syncContactFormState();
      }
    });

    document.addEventListener("turbo:load", syncContactFormState);
    document.addEventListener("DOMContentLoaded", syncContactFormState);
    syncContactFormState();
  })();
</script>
